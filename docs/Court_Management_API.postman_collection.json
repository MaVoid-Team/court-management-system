        {
          "name": "List Packages",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/packages?branch_id=1&page=1&per_page=25",
              "host": ["{{base_url}}"],
              "path": ["api", "packages"],
              "query": [
                { "key": "branch_id", "value": "1", "disabled": true },
                { "key": "page", "value": "1", "disabled": true },
                { "key": "per_page", "value": "25", "disabled": true }
              ]
            }
          }
        },
